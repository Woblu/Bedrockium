<Page x:Class="AmethystLauncher.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewmodels="clr-namespace:AmethystLauncher.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance viewmodels:HomeViewModel, IsDesignTimeCreatable=False}">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,24,0">
            <TextBlock Text="Version" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <ui:ListView ItemsSource="{Binding Versions}"
                         SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                         DisplayMemberPath="Name"
                         MinHeight="200"
                         Background="Transparent"
                         BorderThickness="0"/>
        </StackPanel>

        <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding SelectedVersion.Name, FallbackValue=Select a version}" FontSize="24" FontWeight="Medium" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="Gray" Margin="0,0,0,16"/>

            <ProgressBar Value="{Binding DownloadProgress, Mode=OneWay}"
                         Minimum="0" Maximum="100"
                         Margin="0,0,0,24"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <Grid Margin="0,0,0,16">
                <ui:Button Content="Launch Minecraft"
                           Command="{Binding LaunchCommand}"
                           HorizontalAlignment="Left"
                           Padding="24,16"
                           FontSize="16"
/>
                <ui:ProgressRing IsIndeterminate="True"
                                 Width="32" Height="32"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
